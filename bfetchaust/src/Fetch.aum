    function cachyArt(out: &![ByteBuf, R]): Unit is
        styled2(&~out, c_reset, c_bold, " ┌──┐"); styled2(&~out, c_nord1, c_bold, " ┌──────────────────────────────────┐ "); styled2(&~out, c_nord11, c_bold, "┌────┐"); nl(&~out);
        styled2(&~out, c_reset, c_bold, " │"); styled(&~out, c_nord1, "▒▒"); styled2(&~out, c_reset, c_bold, "│"); styled2(&~out, c_nord1, c_bold, " │─────"); styled(&~out, c_nord7, "/"); styled(&~out, c_nord3, "--"); styled(&~out, c_nord4, "++++++++++"); styled(&~out, c_nord3, "----"); styled(&~out, c_nord7, "/"); styled2(&~out, c_nord1, c_bold, "───────────│ "); styled2(&~out, c_nord11, c_bold, "│ 境 │"); nl(&~out);
        styled2(&~out, c_reset, c_bold, " │"); styled(&~out, c_nord0, "██"); styled2(&~out, c_reset, c_bold, "│"); styled2(&~out, c_nord1, c_bold, " │────"); styled(&~out, c_nord7, "//"); styled(&~out, c_nord4, "+++++++++++"); styled(&~out, c_nord3, "----"); styled(&~out, c_nord7, "/"); styled2(&~out, c_nord1, c_bold, "─────"); styledTrailBackslashes(&~out, c_nord7, "/", 2 : Index); styled2(&~out, c_nord1, c_bold, "────│ "); styled2(&~out, c_nord11, c_bold, "│    │"); nl(&~out);
        styled2(&~out, c_reset, c_bold, " │"); styled(&~out, c_nord1, "██"); styled2(&~out, c_reset, c_bold, "│"); styled2(&~out, c_nord1, c_bold, " │───"); styled(&~out, c_nord7, "//"); styled(&~out, c_nord4, "++++++++++++++++"); styled2(&~out, c_nord1, c_bold, "──────"); styled(&~out, c_nord7, "\\//"); styled2(&~out, c_nord1, c_bold, "────│ "); styled2(&~out, c_nord11, c_bold, "│ 界 │"); nl(&~out);
        styled2(&~out, c_reset, c_bold, " │"); styled(&~out, c_nord11, "██"); styled2(&~out, c_reset, c_bold, "│"); styled2(&~out, c_nord1, c_bold, " │──"); styled(&~out, c_nord7, "//"); styled(&~out, c_nord4, "++"); styled(&~out, c_nord3, "---"); styled(&~out, c_nord4, "+"); styled(&~out, c_nord7, "//"); styled2(&~out, c_nord1, c_bold, "──────────────────────│ "); styled2(&~out, c_nord11, c_bold, "└────┘"); nl(&~out);
        styled2(&~out, c_reset, c_bold, " │"); styled(&~out, c_nord12, "██"); styled2(&~out, c_reset, c_bold, "│"); styled2(&~out, c_nord1, c_bold, " │─"); styled(&~out, c_nord7, "//"); styled(&~out, c_nord3, "---"); styled(&~out, c_nord4, "+++"); styled(&~out, c_nord7, "//"); styled2(&~out, c_nord1, c_bold, "────────────"); styledTrailBackslashes(&~out, c_nord7, "/+", 2 : Index); styled2(&~out, c_nord1, c_bold, "───────│"); nl(&~out);
        styled2(&~out, c_reset, c_bold, " │"); styled(&~out, c_nord13, "██"); styled2(&~out, c_reset, c_bold, "│"); styled2(&~out, c_nord1, c_bold, " │─"); coloredBackslashes(&~out, c_nord7, 2 : Index); styled(&~out, c_nord4, "++++"); styled(&~out, c_nord3, "--"); styled(&~out, c_nord7, "/"); styled2(&~out, c_nord1, c_bold, "─────────────"); styled(&~out, c_nord7, "\\-//"); styled2(&~out, c_nord1, c_bold, "───────│"); nl(&~out);
        styled2(&~out, c_reset, c_bold, " │"); styled(&~out, c_nord14, "██"); styled2(&~out, c_reset, c_bold, "│"); styled2(&~out, c_nord1, c_bold, " │──"); coloredBackslashes(&~out, c_nord7, 2 : Index); styled(&~out, c_nord3, "--"); styled(&~out, c_nord4, "+++"); coloredBackslashes(&~out, c_nord7, 1 : Index); styled2(&~out, c_nord1, c_bold, "──────────────────"); styledTrailBackslashes(&~out, c_nord7, "/++", 2 : Index); styled2(&~out, c_nord1, c_bold, "─│"); nl(&~out);
