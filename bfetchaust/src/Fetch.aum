        styled2(&~out, c_reset, c_bold, " │"); styled(&~out, c_nord9, "██"); styled2(&~out, c_reset, c_bold, "│"); styled2(&~out, c_nord1, c_bold, " │─────"); coloredBackslashes(&~out, c_nord7, 1 : Index); styled(&~out, c_nord3, "--"); styled(&~out, c_nord4, "+++++++++++++++"); styled(&~out, c_nord3, "--"); styled(&~out, c_nord7, "/"); styled2(&~out, c_nord1, c_bold, "────────│"); nl(&~out);
        styled2(&~out, c_reset, c_bold, " │"); styled(&~out, c_nord10, "██"); styled2(&~out, c_reset, c_bold, "│"); styled2(&~out, c_nord1, c_bold, " │──────"); coloredBackslashes(&~out, c_nord7, 1 : Index); styled(&~out, c_nord3, "-"); styled(&~out, c_nord4, "++++++++++++"); styled(&~out, c_nord3, "----"); styled(&~out, c_nord7, "/"); styled2(&~out, c_nord1, c_bold, "─────────│"); nl(&~out);
        styled2(&~out, c_reset, c_bold, " │"); styled(&~out, c_nord15, "██"); styled2(&~out, c_reset, c_bold, "│"); styled2(&~out, c_nord1, c_bold, " └──────────────────────────────────┘"); nl(&~out);
        return nil;
    end;

    generic [R: Region, S: Region, T: Region, U: Region, V: Region, W: Region, X: Region, Y: Region, Z: Region, A0: Region, A1: Region]
    function renderFetch(
        out: &![ByteBuf, R],
        ty: SystemType,
        distro: &[ByteBuf, S],
        kernel: &[ByteBuf, T],
        uptime: &[ByteBuf, U],
        wm: &[ByteBuf, V],
        packages: &[ByteBuf, W],
        terminal: &[ByteBuf, X],
        memory: &[ByteBuf, Y],
        shell: &[ByteBuf, Z],
        cpu: &[ByteBuf, A0],
        gpu: &[ByteBuf, A1]
    ): Unit is
        case ty of
            when GentooMode do
                gentooArt(&~out);
                fieldLine(&~out, c_nord8, "██", c_nord12, "Distro: ", distro);
                fieldLine(&~out, c_nord9, "██", c_nord12, "Kernel: ", kernel);
                fieldLine(&~out, c_nord10, "██", c_nord15, "Uptime: ", uptime);
                fieldLine(&~out, c_nord15, "██", c_nord15, "WM: ", wm);
                fieldLine(&~out, c_nord11, "██", c_nord15, "Packages: ", packages);
                fieldLine(&~out, c_nord12, "██", c_nord13, "Terminal: ", terminal);
                fieldLine(&~out, c_nord13, "██", c_nord13, "Memory: ", memory);
                fieldLine(&~out, c_nord14, "██", c_nord13, "Shell: ", shell);
                fieldLine(&~out, c_nord7, "██", c_nord9, "CPU: ", cpu);
                fieldLine(&~out, c_nord1, "▒▒", c_nord9, "GPU: ", gpu);
            when CachyMode do
                cachyArt(&~out);
                fieldLine(&~out, c_nord7, "██", c_nord12, "Distro: ", distro);
                fieldLine(&~out, c_nord8, "██", c_nord12, "Kernel: ", kernel);
                fieldLine(&~out, c_nord9, "██", c_nord15, "Uptime: ", uptime);
                fieldLine(&~out, c_nord10, "██", c_nord15, "WM: ", wm);
                fieldLine(&~out, c_nord15, "██", c_nord15, "Packages: ", packages);
                fieldLine(&~out, c_nord11, "██", c_nord13, "Terminal: ", terminal);
                fieldLine(&~out, c_nord12, "██", c_nord13, "Memory: ", memory);
                fieldLine(&~out, c_nord13, "██", c_nord13, "Shell: ", shell);
                fieldLine(&~out, c_nord14, "██", c_nord9, "CPU: ", cpu);
                fieldLine(&~out, c_nord1, "▒▒", c_nord9, "GPU: ", gpu);
            when BedrockMode do
                bedrockArt(&~out);
                fieldLine(&~out, c_nord7, "██", c_nord12, "Distro: ", distro);
                fieldLine(&~out, c_nord8, "██", c_nord12, "Kernel: ", kernel);
                fieldLine(&~out, c_nord9, "██", c_nord15, "Uptime: ", uptime);
                fieldLine(&~out, c_nord10, "██", c_nord15, "WM: ", wm);
                fieldLine(&~out, c_nord15, "██", c_nord15, "Packages: ", packages);
                fieldLine(&~out, c_nord11, "██", c_nord13, "Terminal: ", terminal);
                fieldLine(&~out, c_nord12, "██", c_nord13, "Memory: ", memory);
                fieldLine(&~out, c_nord13, "██", c_nord13, "Shell: ", shell);
                fieldLine(&~out, c_nord14, "██", c_nord9, "CPU: ", cpu);
                fieldLine(&~out, c_nord1, "▒▒", c_nord9, "GPU: ", gpu);
            when OtherMode do
                bedrockArt(&~out);
                fieldLine(&~out, c_nord7, "██", c_nord12, "Distro: ", distro);
                fieldLine(&~out, c_nord8, "██", c_nord12, "Kernel: ", kernel);
                fieldLine(&~out, c_nord9, "██", c_nord15, "Uptime: ", uptime);
                fieldLine(&~out, c_nord10, "██", c_nord15, "WM: ", wm);
                fieldLine(&~out, c_nord15, "██", c_nord15, "Packages: ", packages);
                fieldLine(&~out, c_nord11, "██", c_nord13, "Terminal: ", terminal);
                fieldLine(&~out, c_nord12, "██", c_nord13, "Memory: ", memory);
                fieldLine(&~out, c_nord13, "██", c_nord13, "Shell: ", shell);
                fieldLine(&~out, c_nord14, "██", c_nord9, "CPU: ", cpu);
                fieldLine(&~out, c_nord1, "▒▒", c_nord9, "GPU: ", gpu);
        end case;
        tailLine(&~out);
        return nil;
    end;

    function main(root: RootCapability): ExitCode is
        var forced_mode: SystemType := OtherMode();
        var has_forced_mode: Bool := false;
        var show_help: Bool := false;
        var show_version: Bool := false;
        let argc: Index := argumentCount();
        if argc > (1 : Index) then
            for i from 1 to argc - 1 do
                let arg: Span[Nat8, Static] := nthArgument(i);
                if spanEquals(arg, "--gentoo") then
                    forced_mode := GentooMode();
                    has_forced_mode := true;
                else if spanEquals(arg, "--cachyos") then
                    forced_mode := CachyMode();
                    has_forced_mode := true;
                else if spanEquals(arg, "--bedrock") then
                    forced_mode := BedrockMode();
                    has_forced_mode := true;
                else if spanEquals(arg, "-v") then
                    show_version := true;
                else if spanEquals(arg, "--version") then
                    show_version := true;
                else if spanEquals(arg, "-h") then
                    show_help := true;
                else if spanEquals(arg, "--help") then
                    show_help := true;
                else if spanEquals(arg, "--Help") then
                    show_help := true;
                end if;
            end for;
        end if;

        var out: ByteBuf := makeByteBuf(16384 : Index);
        if show_help then
            appendHelp(&!out);
            writeAll(stdout_fd, &out);
            destroyByteBuf(out);
        else if show_version then
            appendVersion(&!out);
            writeAll(stdout_fd, &out);
            destroyByteBuf(out);
        else
            var distro: ByteBuf := makeByteBuf(256 : Index);
            var kernel: ByteBuf := makeByteBuf(256 : Index);
            var uptime: ByteBuf := makeByteBuf(256 : Index);
            var memory: ByteBuf := makeByteBuf(256 : Index);
            var wm: ByteBuf := makeByteBuf(256 : Index);
            var terminal: ByteBuf := makeByteBuf(256 : Index);
            var shell: ByteBuf := makeByteBuf(256 : Index);
            var cpu: ByteBuf := makeByteBuf(256 : Index);
            var gpu: ByteBuf := makeByteBuf(256 : Index);
            var packages: ByteBuf := makeByteBuf(1024 : Index);
            var system_type: SystemType := getDistroAndType(&!distro);
            if has_forced_mode then
                system_type := forced_mode;
            end if;

            getKernel(&!kernel);
            getUptime(&!uptime);
            getMemory(&!memory);
            getWm(&!wm);
            getTerminal(&!terminal);
            getCpu(&!cpu);
            getGpu(&!gpu);
            getPackages(&!packages, system_type);
            getShell(&!shell);
            renderFetch(&!out, system_type, &distro, &kernel, &uptime, &wm, &packages, &terminal, &memory, &shell, &cpu, &gpu);
            writeAll(stdout_fd, &out);

            destroyByteBuf(packages);
            destroyByteBuf(gpu);
            destroyByteBuf(cpu);
            destroyByteBuf(shell);
            destroyByteBuf(terminal);
            destroyByteBuf(wm);
            destroyByteBuf(memory);
            destroyByteBuf(uptime);
            destroyByteBuf(kernel);
            destroyByteBuf(distro);
            destroyByteBuf(out);
        end if;
        surrenderRoot(root);
        return ExitSuccess();
    end;
end module body.
