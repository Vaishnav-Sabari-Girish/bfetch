import BfetchAust.Posix (
    stdout_fd
);
import BfetchAust.FastIO (
    ByteBuf,
    makeByteBuf,
    destroyByteBuf,
    data,
    appendByte,
    appendSpan,
    appendCString,
    appendIndexDecimal,
    writeAll
);
import BfetchAust.Sys (
    SystemType,
    BedrockMode,
    GentooMode,
    CachyMode,
    OtherMode,
    getDistroAndType,
    getKernel,
    getUptime,
    getMemory,
    getWm,
    getTerminal,
    getShell,
    getPackages,
    getCpu,
    getGpu
);

module body BfetchAust.Fetch is
    constant c_reset: Index := 0;
    constant c_bold: Index := 1;
    constant c_nord0: Index := 30;
    constant c_nord1: Index := 90;
    constant c_nord3: Index := 97;
    constant c_nord4: Index := 97;
    constant c_nord7: Index := 36;
    constant c_nord8: Index := 96;
    constant c_nord9: Index := 34;
    constant c_nord10: Index := 94;
    constant c_nord11: Index := 91;
    constant c_nord12: Index := 93;
    constant c_nord13: Index := 33;
    constant c_nord14: Index := 32;
    constant c_nord15: Index := 95;

    function spanEquals(left: Span[Nat8, Static], right: Span[Nat8, Static]): Bool is
        let left_len: Index := spanLength(left);
        let right_len: Index := spanLength(right);
        if left_len /= right_len then
            return false;
        end if;
        if left_len > (0 : Index) then
            for i from 0 to left_len - 1 do
                if left[i] /= right[i] then
                    return false;
                end if;
            end for;
        end if;
        return true;
    end;

    generic [R: Region]
    function ansi(out: &![ByteBuf, R], code: Index): Unit is
        appendByte(&~out, 27 : Nat8);
        appendByte(&~out, '[');
        appendIndexDecimal(&~out, code);
        appendByte(&~out, 'm');
        return nil;
    end;

    generic [R: Region, S: Region]
    function styled(out: &![ByteBuf, R], code: Index, text: Span[Nat8, S]): Unit is
        ansi(&~out, code);
        appendSpan(&~out, text);
        return nil;
    end;

    generic [R: Region, S: Region]
    function styled2(out: &![ByteBuf, R], code0: Index, code1: Index, text: Span[Nat8, S]): Unit is
        ansi(&~out, code0);
        ansi(&~out, code1);
        appendSpan(&~out, text);
        return nil;
    end;

    generic [R: Region]
    function nl(out: &![ByteBuf, R]): Unit is
        appendByte(&~out, 10 : Nat8);
        return nil;
    end;

    generic [R: Region]
    function backslashes(out: &![ByteBuf, R], count: Index): Unit is
        if count > (0 : Index) then
            for i from 1 to count do
                appendByte(&~out, '\\');
            end for;
        end if;
        return nil;
    end;

    generic [R: Region, S: Region]
    function appendValue(out: &![ByteBuf, R], value: &[ByteBuf, S]): Unit is
        appendCString(&~out, data(value));
        return nil;
    end;

    generic [R: Region]
    function styledBackslashes(out: &![ByteBuf, R], code0: Index, code1: Index, count: Index): Unit is
        ansi(&~out, code0);
        ansi(&~out, code1);
        backslashes(&~out, count);
        return nil;
    end;

    generic [R: Region]
    function coloredBackslashes(out: &![ByteBuf, R], code: Index, count: Index): Unit is
        ansi(&~out, code);
        backslashes(&~out, count);
        return nil;
    end;

    generic [R: Region, S: Region]
    function styledTrailBackslashes(out: &![ByteBuf, R], code: Index, text: Span[Nat8, S], count: Index): Unit is
        styled(&~out, code, text);
        backslashes(&~out, count);
        return nil;
    end;

    generic [R: Region, S: Region]
    function styled2TrailBackslashes(out: &![ByteBuf, R], code0: Index, code1: Index, text: Span[Nat8, S], count: Index): Unit is
        styled2(&~out, code0, code1, text);
        backslashes(&~out, count);
        return nil;
    end;

    generic [R: Region, S: Region]
    function fieldLine(
        out: &![ByteBuf, R],
        bar_code: Index,
        bar_text: Span[Nat8, Static],
        label_code: Index,
        label: Span[Nat8, Static],
        value: &[ByteBuf, S]
    ): Unit is
        styled2(&~out, c_reset, c_bold, " │");
        styled(&~out, bar_code, bar_text);
        styled2(&~out, c_reset, c_bold, "│ ");
        styled(&~out, label_code, label);
        ansi(&~out, c_nord4);
        appendValue(&~out, value);
        nl(&~out);
        return nil;
    end;

    generic [R: Region]
    function tailLine(out: &![ByteBuf, R]): Unit is
        styled2(&~out, c_reset, c_bold, " └──┘");
        ansi(&~out, c_reset);
        nl(&~out);
        return nil;
    end;

    generic [R: Region]
    function appendHelp(out: &![ByteBuf, R]): Unit is
        appendSpan(&~out, "Usage: ./bfetch [OPTIONS]");
        nl(&~out);
        appendSpan(&~out, "Options:");
        nl(&~out);
        appendSpan(&~out, "  -v, --version    Show version");
        nl(&~out);
        appendSpan(&~out, "  -h, --Help       Show this help");
        nl(&~out);
        appendSpan(&~out, "  --gentoo         Force Gentoo mode");
        nl(&~out);
        appendSpan(&~out, "  --cachyos        Force CachyOS mode");
        nl(&~out);
        appendSpan(&~out, "  --bedrock        Force Bedrock mode");
        nl(&~out);
        return nil;
    end;

    generic [R: Region]
    function appendVersion(out: &![ByteBuf, R]): Unit is
        appendSpan(&~out, "bfetch version 2.4.0-fastasf");
        nl(&~out);
        return nil;
    end;

    generic [R: Region]
    function gentooArt(out: &![ByteBuf, R]): Unit is
        styled2(&~out, c_reset, c_bold, " ┌──┐"); styled(&~out, c_nord1, " ┌──────────────────────────────────┐ "); styled2(&~out, c_nord15, c_bold, "┌─────┐"); nl(&~out);
        styled2(&~out, c_reset, c_bold, " │"); styled(&~out, c_nord1, "▒▒"); styled2(&~out, c_reset, c_bold, "│"); styled(&~out, c_nord1, " │─────────"); styledBackslashes(&~out, c_reset, c_bold, 10 : Index); styled(&~out, c_nord1, "───────────────│ "); styled2(&~out, c_nord15, c_bold, "│  G  │"); nl(&~out);
        styled2(&~out, c_reset, c_bold, " │"); styled(&~out, c_nord0, "██"); styled2(&~out, c_reset, c_bold, "│"); styled(&~out, c_nord1, " │───────"); styled2TrailBackslashes(&~out, c_reset, c_bold, "//+++++++++++", 1 : Index); styled(&~out, c_nord1, "─────────────│ "); styled2(&~out, c_nord15, c_bold, "│  e  │"); nl(&~out);
        styled2(&~out, c_reset, c_bold, " │"); styled(&~out, c_nord1, "██"); styled2(&~out, c_reset, c_bold, "│"); styled(&~out, c_nord1, " │──────"); styled2(&~out, c_reset, c_bold, "//+++++"); styledBackslashes(&~out, c_nord1, c_bold, 3 : Index); styled2TrailBackslashes(&~out, c_reset, c_bold, "+++++", 1 : Index); styled(&~out, c_nord1, "────────────│ "); styled2(&~out, c_nord15, c_bold, "│  n  │"); nl(&~out);
        styled2(&~out, c_reset, c_bold, " │"); styled(&~out, c_nord11, "██"); styled2(&~out, c_reset, c_bold, "│"); styled(&~out, c_nord1, " │─────"); styled2(&~out, c_reset, c_bold, "//+++++"); styled2(&~out, c_nord1, c_bold, "// "); styled(&~out, c_reset, "/"); styled2TrailBackslashes(&~out, c_reset, c_bold, "+++++++", 1 : Index); styled(&~out, c_nord1, "──────────│ "); styled2(&~out, c_nord15, c_bold, "│  t  │"); nl(&~out);
        styled2(&~out, c_reset, c_bold, " │"); styled(&~out, c_nord12, "██"); styled2(&~out, c_reset, c_bold, "│"); styled(&~out, c_nord1, " │──────"); styled2(&~out, c_reset, c_bold, "+++++++"); styledBackslashes(&~out, c_nord1, c_bold, 2 : Index); styled2TrailBackslashes(&~out, c_reset, c_bold, "++++++++++", 1 : Index); styled(&~out, c_nord1, "────────│ "); styled2(&~out, c_nord15, c_bold, "│  o  │"); nl(&~out);
        styled2(&~out, c_reset, c_bold, " │"); styled(&~out, c_nord13, "██"); styled2(&~out, c_reset, c_bold, "│"); styled(&~out, c_nord1, " │────────"); styled2(&~out, c_reset, c_bold, "++++++++++++++++++"); styledBackslashes(&~out, c_nord1, c_bold, 2 : Index); styled(&~out, c_nord1, "──────│ "); styled2(&~out, c_nord15, c_bold, "│  o  │"); nl(&~out);
        styled2(&~out, c_reset, c_bold, " │"); styled(&~out, c_nord14, "██"); styled2(&~out, c_reset, c_bold, "│"); styled(&~out, c_nord1, " │─────────"); styled2(&~out, c_reset, c_bold, "//++++++++++++++"); styled2(&~out, c_nord1, c_bold, "//"); styled(&~out, c_nord1, "───────│ "); styled2(&~out, c_nord15, c_bold, "└─────┘"); nl(&~out);
        styled2(&~out, c_reset, c_bold, " │"); styled(&~out, c_nord7, "██"); styled2(&~out, c_reset, c_bold, "│"); styled(&~out, c_nord1, " │───────"); styled2(&~out, c_reset, c_bold, "//++++++++++++++"); styled2(&~out, c_nord1, c_bold, "//"); styled(&~out, c_nord1, "─────────│ "); nl(&~out);
        styled2(&~out, c_reset, c_bold, " │"); styled(&~out, c_nord8, "██"); styled2(&~out, c_reset, c_bold, "│"); styled(&~out, c_nord1, " │──── "); styled2(&~out, c_reset, c_bold, "//++++++++++++++"); styled2(&~out, c_nord1, c_bold, "//"); styled(&~out, c_nord1, "───────────│ "); nl(&~out);
        styled2(&~out, c_reset, c_bold, " │"); styled(&~out, c_nord9, "██"); styled2(&~out, c_reset, c_bold, "│"); styled(&~out, c_nord1, " │─────"); styled2(&~out, c_reset, c_bold, "//++++++++++"); styled2(&~out, c_nord1, c_bold, "//"); styled(&~out, c_nord1, "───────────────│"); nl(&~out);
        styled2(&~out, c_reset, c_bold, " │"); styled(&~out, c_nord10, "██"); styled2(&~out, c_reset, c_bold, "│"); styled(&~out, c_nord1, " │─────"); styled2(&~out, c_reset, c_bold, "//+++++++"); styled2(&~out, c_nord1, c_bold, "//"); styled(&~out, c_nord1, "──────────────────│"); nl(&~out);
        styled2(&~out, c_reset, c_bold, " │"); styled(&~out, c_nord15, "██"); styled2(&~out, c_reset, c_bold, "│"); styled(&~out, c_nord1, " │──────"); styled2(&~out, c_reset, c_bold, "////////"); styled2(&~out, c_nord1, c_bold, "────────────────────│"); nl(&~out);
        styled2(&~out, c_reset, c_bold, " │"); styled(&~out, c_nord7, "██"); styled2(&~out, c_reset, c_bold, "│"); styled(&~out, c_nord1, " └──────────────────────────────────┘"); nl(&~out);
        return nil;
    end;

    generic [R: Region]
    function bedrockArt(out: &![ByteBuf, R]): Unit is
        styled2(&~out, c_reset, c_bold, " ┌──┐"); styled2(&~out, c_nord1, c_bold, " ┌──────────────────────────────────┐ "); styled2(&~out, c_nord11, c_bold, "┌────┐"); nl(&~out);
        styled2(&~out, c_reset, c_bold, " │"); styled(&~out, c_nord1, "▒▒"); styled2(&~out, c_reset, c_bold, "│"); styled2(&~out, c_nord1, c_bold, " │─"); styledBackslashes(&~out, c_reset, c_bold, 13 : Index); styled2(&~out, c_nord1, c_bold, "────────────────────│ "); styled2(&~out, c_nord11, c_bold, "│ 境 │"); nl(&~out);
        styled2(&~out, c_reset, c_bold, " │"); styled(&~out, c_nord0, "██"); styled2(&~out, c_reset, c_bold, "│"); styled2(&~out, c_nord1, c_bold, " │──"); styled2TrailBackslashes(&~out, c_reset, c_bold, "\\\\\\      ", 3 : Index); styled2(&~out, c_nord1, c_bold, "────────────────────│ "); styled2(&~out, c_nord11, c_bold, "│    │"); nl(&~out);
        styled2(&~out, c_reset, c_bold, " │"); styled(&~out, c_nord1, "██"); styled2(&~out, c_reset, c_bold, "│"); styled2(&~out, c_nord1, c_bold, " │───"); styled2TrailBackslashes(&~out, c_reset, c_bold, "\\\\\\      ", 3 : Index); styled2(&~out, c_nord1, c_bold, "───────────────────│ "); styled2(&~out, c_nord11, c_bold, "│ 界 │"); nl(&~out);
        styled2(&~out, c_reset, c_bold, " │"); styled(&~out, c_nord11, "██"); styled2(&~out, c_reset, c_bold, "│"); styled2(&~out, c_nord1, c_bold, " │────"); styled2TrailBackslashes(&~out, c_reset, c_bold, "\\\\\\      ", 17 : Index); styled2(&~out, c_nord1, c_bold, "────│ "); styled2(&~out, c_nord11, c_bold, "└────┘"); nl(&~out);
        styled2(&~out, c_reset, c_bold, " │"); styled(&~out, c_nord12, "██"); styled2(&~out, c_reset, c_bold, "│"); styled2(&~out, c_nord1, c_bold, " │─────"); styled2TrailBackslashes(&~out, c_reset, c_bold, "\\\\\\                    ", 3 : Index); styled2(&~out, c_nord1, c_bold, "───│"); nl(&~out);
        styled2(&~out, c_reset, c_bold, " │"); styled(&~out, c_nord13, "██"); styled2(&~out, c_reset, c_bold, "│"); styled2(&~out, c_nord1, c_bold, " │──────"); styled2TrailBackslashes(&~out, c_reset, c_bold, "\\\\\\                    ", 3 : Index); styled2(&~out, c_nord1, c_bold, "──│"); nl(&~out);
        styled2(&~out, c_reset, c_bold, " │"); styled(&~out, c_nord14, "██"); styled2(&~out, c_reset, c_bold, "│"); styled2(&~out, c_nord1, c_bold, " │───────"); styled2TrailBackslashes(&~out, c_reset, c_bold, "\\\\\\        ──────      ", 3 : Index); styled2(&~out, c_nord1, c_bold, "─│"); nl(&~out);
        styled2(&~out, c_reset, c_bold, " │"); styled(&~out, c_nord7, "██"); styled2(&~out, c_reset, c_bold, "│"); styled2(&~out, c_nord1, c_bold, " │────────"); styled2(&~out, c_reset, c_bold, "\\\\\\                   ///"); styled2(&~out, c_nord1, c_bold, "─│"); nl(&~out);
        styled2(&~out, c_reset, c_bold, " │"); styled(&~out, c_nord8, "██"); styled2(&~out, c_reset, c_bold, "│"); styled2(&~out, c_nord1, c_bold, " │─────────"); styled2(&~out, c_reset, c_bold, "\\\\\\                 ///"); styled2(&~out, c_nord1, c_bold, "──│"); nl(&~out);
        styled2(&~out, c_reset, c_bold, " │"); styled(&~out, c_nord9, "██"); styled2(&~out, c_reset, c_bold, "│"); styled2(&~out, c_nord1, c_bold, " │──────────"); styled2(&~out, c_reset, c_bold, "\\\\\\               ///"); styled2(&~out, c_nord1, c_bold, "───│"); nl(&~out);
        styled2(&~out, c_reset, c_bold, " │"); styled(&~out, c_nord10, "██"); styled2(&~out, c_reset, c_bold, "│"); styled2(&~out, c_nord1, c_bold, " │───────────"); styled2(&~out, c_reset, c_bold, "\\\\\\////////////////"); styled2(&~out, c_nord1, c_bold, "────│"); nl(&~out);
        styled2(&~out, c_reset, c_bold, " │"); styled(&~out, c_nord15, "██"); styled2(&~out, c_reset, c_bold, "│"); styled2(&~out, c_nord1, c_bold, " └──────────────────────────────────┘"); nl(&~out);
